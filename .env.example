# ==============================================================================
# CLOUDFLARE SETUP
# ==============================================================================

# Account ID: Found in the Cloudflare dashboard URL or on the right sidebar of Workers/R2 pages.
CLOUDFLARE_ACCOUNT_ID=your_account_id_here

# API Token: Generated at https://dash.cloudflare.com/profile/api-tokens
# Required Permissions:
# - Account > Workers Scripts > Edit
# - All Domains (or Specified Domain) > Developer Platform > Workers Routes > Edit
# - Account > R2 Storage > Edit
CLOUDFLARE_API_TOKEN=your_cloudflare_token_here

# R2 S3-Compatible Credentials: 
# Generated at Cloudflare Dashboard > R2 > "Manage R2 API Tokens"
# Required Permission: "Object Read & Write"
# Why? GitHub Actions uses this via AWS CLI to aggressively empty buckets before Pulumi destroys them.
CLOUDFLARE_R2_ACCESS_KEY_ID=your_r2_access_key
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your_r2_secret_key

# ==============================================================================
# PULUMI SETUP
# ==============================================================================

# Access Token: Generated at https://app.pulumi.com/ > Profile / Settings > Access Tokens
# Why? Allows Pulumi CLI in GitHub Actions to authenticate and save state securely to Pulumi Cloud.
PULUMI_ACCESS_TOKEN=your_pulumi_token_here

# ==============================================================================
# APP SECRETS & NAMESPACE
# ==============================================================================

# Namespace prefix used for naming all deployed resources securely (e.g., nxt-one).
# Keep this very short to avoid hitting Cloudflare's 63-character naming limits.
RESOURCE_NAMESPACE=nxt-one

# Runtime Secret: An example application secret that will be securely accessible inside your Next.js Edge Worker.
DEMO_SECRET_KEY=my_production_secret
