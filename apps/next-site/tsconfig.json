{
	"extends": "@design_components/config/tsconfig.next.json",
	"compilerOptions": {
		"target": "es2024",
		"moduleResolution": "bundler",
		"paths": {
			"@/*": ["./src/*"]
		},
		"types": ["./cloudflare-env.d.ts", "node"]
	},
	"include": [
		"cloudflare-env.d.ts",
		"next-env.d.ts",
		"**/*.ts",
		"**/*.tsx",
		".next/types/**/*.ts",
		".next/dev/types/**/*.ts"
	],
	"exclude": ["node_modules"]
}
