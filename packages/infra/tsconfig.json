{
	"compilerOptions": {
		"strict": true,
		"outDir": "bin",
		"module": "NodeNext",
		"sourceMap": true,
		"experimentalDecorators": true,
		"pretty": true,
		"noFallthroughCasesInSwitch": true,
		"noImplicitReturns": true,
		"forceConsistentCasingInFileNames": true,
		"moduleResolution": "NodeNext"
	},
	"include": ["index.ts"]
}
