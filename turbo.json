{
	"$schema": "https://turbo.build/schema.json",
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"outputs": ["dist/**", ".next/**", "!.next/cache/**", "storybook-static/**"]
		},
		"test": {
			"dependsOn": ["^test"]
		},
		"typecheck": {
			"dependsOn": ["^typecheck"]
		},
		"dev": {
			"cache": false,
			"persistent": true
		},
		"//#lint": {
			"inputs": ["**/*.ts", "**/*.tsx", "**/*.js", "biome.json", "**/*.mjs"],
			"outputs": []
		},
		"//#format": {
			"inputs": ["**/*.ts", "**/*.tsx", "**/*.js", "biome.json", "**/*.mjs"],
			"outputs": []
		}
	}
}
